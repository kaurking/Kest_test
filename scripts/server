#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="$ROOT_DIR/.venv"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/server.pid"
LOG_FILE="$RUN_DIR/server.log"
HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-8000}"

cd "$ROOT_DIR"

ensure_venv() {
  if [[ ! -x "$VENV_DIR/bin/python" ]]; then
    python3 -m venv "$VENV_DIR"
  fi
}

install_dependencies() {
  ensure_venv
  "$VENV_DIR/bin/pip" install -r requirements.txt
}

init_database() {
  ensure_venv
  "$VENV_DIR/bin/python" scripts/db_init
}

import_offers() {
  ensure_venv
  "$VENV_DIR/bin/python" scripts/db_import_offers --replace
}

is_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

port_listener() {
  lsof -nP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true
}

start_server() {
  ensure_venv
  mkdir -p "$RUN_DIR"

  if is_running; then
    echo "Server is already running: http://$HOST:$PORT"
    echo "PID: $(cat "$PID_FILE")"
    return
  fi

  : > "$LOG_FILE"
  nohup "$VENV_DIR/bin/uvicorn" app.main:app --host "$HOST" --port "$PORT" >> "$LOG_FILE" 2>&1 &
  echo "$!" > "$PID_FILE"
  sleep 1

  if is_running; then
    echo "Server started: http://$HOST:$PORT"
    echo "PID: $(cat "$PID_FILE")"
    echo "Logs: $LOG_FILE"
  else
    echo "Server failed to start. Logs:"
    tail -n 40 "$LOG_FILE"
    rm -f "$PID_FILE"
    exit 1
  fi
}

dev_server() {
  ensure_venv
  "$VENV_DIR/bin/uvicorn" app.main:app --reload --host "$HOST" --port "$PORT"
}

stop_server() {
  if ! is_running; then
    echo "Server is not running."
    rm -f "$PID_FILE"
    return
  fi

  local pid
  pid="$(cat "$PID_FILE")"
  kill "$pid"

  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$PID_FILE"
      echo "Server stopped."
      return
    fi
    sleep 0.2
  done

  echo "Server did not stop in time. PID: $pid"
  echo "You can force stop manually with: kill -9 $pid"
  exit 1
}

server_status() {
  if is_running; then
    echo "Server is running: http://$HOST:$PORT"
    echo "PID: $(cat "$PID_FILE")"
    echo "Logs: $LOG_FILE"
  else
    rm -f "$PID_FILE"
    echo "Server is not running."
  fi

  local listener
  listener="$(port_listener)"
  if [[ -n "$listener" ]]; then
    echo
    echo "Port $PORT is currently in use:"
    echo "$listener"
  fi
}

show_logs() {
  if [[ -f "$LOG_FILE" ]]; then
    tail -n 80 "$LOG_FILE"
  else
    echo "No log file found yet."
  fi
}

case "${1:-}" in
  install)
    install_dependencies
    ;;
  db-init)
    init_database
    ;;
  db-import)
    import_offers
    ;;
  dev)
    dev_server
    ;;
  start)
    start_server
    ;;
  stop)
    stop_server
    ;;
  restart)
    stop_server
    start_server
    ;;
  status)
    server_status
    ;;
  logs)
    show_logs
    ;;
  *)
    echo "Usage: scripts/server {install|db-init|db-import|dev|start|stop|restart|status|logs}"
    echo
    echo "Optional environment variables:"
    echo "  PORT=8001 scripts/server dev"
    echo "  PORT=8001 scripts/server start"
    echo "  HOST=0.0.0.0 scripts/server start"
    exit 1
    ;;
esac
